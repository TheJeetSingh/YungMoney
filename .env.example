BOT_MODE=paper
CHAIN_ID=137
CLOB_HOST=https://clob.polymarket.com
GAMMA_HOST=https://gamma-api.polymarket.com

# Magic Link setup (POLY_PROXY)
SIGNATURE_TYPE=1
PRIVATE_KEY=0xYOUR_EXPORTED_MAGICLINK_PRIVATE_KEY
FUNDER_ADDRESS=0xYOUR_POLYMARKET_PROXY_WALLET

# Optional: pin explicit L2 creds, otherwise derived at startup.
API_KEY=
SECRET=
PASSPHRASE=

# Strategy
BANKROLL_USD=10
QUOTE_REFRESH_MS=500
MAX_INVENTORY=100
EXIT_DEADLINE_SEC=240
MAX_DAILY_DRAWDOWN_PCT=0.20
MAX_CONSECUTIVE_POST_FAILS=8
STALE_DATA_SECONDS=5

# Optional market filter override
MARKET_TAG=crypto
MIN_EQUITY_FLOOR_PCT=0.75
